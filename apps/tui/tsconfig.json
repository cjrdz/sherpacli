{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM"],
		"jsx": "preserve",
		"jsxImportSource": "@opentui/solid",
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"types": ["bun"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
