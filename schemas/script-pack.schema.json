{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://sherpacli.dev/schemas/script-pack.schema.json",
	"type": "object",
	"required": ["pack", "scripts"],
	"properties": {
		"pack": {
			"type": "object",
			"required": [
				"id",
				"name",
				"version",
				"description",
				"icon",
				"author",
				"tags"
			],
			"properties": {
				"id": { "type": "string", "minLength": 1 },
				"name": { "type": "string", "minLength": 1 },
				"version": { "type": "string", "minLength": 1 },
				"description": { "type": "string", "minLength": 1 },
				"icon": { "type": "string", "minLength": 1 },
				"author": { "type": "string", "minLength": 1 },
				"tags": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"minItems": 1
				}
			},
			"additionalProperties": true
		},
		"scripts": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": [
					"id",
					"name",
					"description",
					"category",
					"tags",
					"execution"
				],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"name": { "type": "string", "minLength": 1 },
					"description": { "type": "string", "minLength": 1 },
					"icon": { "type": "string" },
					"category": { "type": "string", "minLength": 1 },
					"tags": {
						"type": "array",
						"items": { "type": "string", "minLength": 1 }
					},
					"requires": {
						"type": "array",
						"items": { "type": "string", "minLength": 1 }
					},
					"danger_level": {
						"type": "string",
						"enum": ["safe", "caution", "destructive"]
					},
					"execution": {
						"type": "object",
						"required": ["type"],
						"properties": {
							"type": {
								"type": "string",
								"enum": ["inline", "file", "menu"]
							},
							"shell": { "type": "string" },
							"command": { "type": "string" },
							"path": { "type": "string" },
							"options": {
								"type": "array",
								"items": {
									"type": "object",
									"required": ["label", "command"],
									"properties": {
										"label": { "type": "string", "minLength": 1 },
										"command": { "type": "string", "minLength": 1 }
									},
									"additionalProperties": true
								}
							},
							"args": {
								"type": "array",
								"items": {
									"type": "object",
									"required": ["name", "prompt"],
									"properties": {
										"name": { "type": "string", "minLength": 1 },
										"prompt": { "type": "string", "minLength": 1 },
										"default": { "type": "string" }
									},
									"additionalProperties": true
								}
							}
						},
						"additionalProperties": true
					}
				},
				"additionalProperties": true
			}
		}
	},
	"additionalProperties": true
}
