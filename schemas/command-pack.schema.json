{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://sherpacli.dev/schemas/command-pack.schema.json",
	"type": "object",
	"required": ["pack", "commands"],
	"properties": {
		"pack": {
			"type": "object",
			"required": [
				"id",
				"name",
				"version",
				"description",
				"icon",
				"author",
				"tags"
			],
			"properties": {
				"id": { "type": "string", "minLength": 1 },
				"name": { "type": "string", "minLength": 1 },
				"version": { "type": "string", "minLength": 1 },
				"description": { "type": "string", "minLength": 1 },
				"icon": { "type": "string", "minLength": 1 },
				"author": { "type": "string", "minLength": 1 },
				"tags": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"minItems": 1
				}
			},
			"additionalProperties": true
		},
		"commands": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": [
					"id",
					"name",
					"description",
					"command",
					"use_case",
					"category",
					"tags",
					"examples"
				],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"name": { "type": "string", "minLength": 1 },
					"description": { "type": "string", "minLength": 1 },
					"command": { "type": "string", "minLength": 1 },
					"use_case": { "type": "string", "minLength": 1 },
					"category": { "type": "string", "minLength": 1 },
					"tags": {
						"type": "array",
						"items": { "type": "string", "minLength": 1 }
					},
					"platform": {
						"type": "array",
						"items": { "type": "string", "enum": ["linux", "macos", "windows"] }
					},
					"requires": {
						"type": "array",
						"items": { "type": "string", "minLength": 1 }
					},
					"examples": {
						"type": "array",
						"minItems": 1,
						"items": {
							"type": "object",
							"required": ["description", "command"],
							"properties": {
								"description": { "type": "string", "minLength": 1 },
								"command": { "type": "string", "minLength": 1 }
							},
							"additionalProperties": true
						}
					},
					"see_also": {
						"type": "array",
						"items": { "type": "string", "minLength": 1 }
					},
					"danger_level": {
						"type": "string",
						"enum": ["safe", "caution", "destructive"]
					}
				},
				"additionalProperties": true
			}
		}
	},
	"additionalProperties": true
}
